# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development           # set to "production" on Render (done via render.yaml)

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas: Database Access → create user → copy the SRV connection string.
# Rotate the password before first deploy.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a new secret:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# On Render, leave this blank — render.yaml sets generateValue:true so Render generates it.
JWT_SECRET=<64-byte-hex-string>
JWT_EXPIRES_IN=24h

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins, no trailing slash.
# Local dev: http://localhost:3000 is added automatically when NODE_ENV != production.
# Production: set to your Vercel URL, e.g. https://cti-guard.vercel.app
CORS_ORIGIN=https://your-app.vercel.app
