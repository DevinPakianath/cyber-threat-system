<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Only the Render backend needs to be declared.
        Android allows HTTPS to any host by default; this config
        prevents any accidental fallback to HTTP.
    -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">cyber-threat-system-2.onrender.com</domain>
    </domain-config>
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">onrender.com</domain>
    </domain-config>
</network-security-config>
